{
  "name": "@shapeshift-labs/frontier-mutation",
  "version": "0.1.4",
  "description": "Explicit mutation and selector plans compiled to Frontier patches or CRDT operations.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/siliconjungle/-shapeshift-labs-frontier-mutation.git"
  },
  "homepage": "https://github.com/siliconjungle/-shapeshift-labs-frontier-mutation#readme",
  "bugs": {
    "url": "https://github.com/siliconjungle/-shapeshift-labs-frontier-mutation/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "benchmarks/package-bench.mjs"
  ],
  "scripts": {
    "build": "node build.mjs",
    "test": "npm run build && npm run typecheck && node test/smoke.mjs",
    "readme:packages": "node benchmarks/package-readme-sections.mjs",
    "readme:packages:check": "node benchmarks/package-readme-sections.mjs --check",
    "prepack": "npm run readme:packages:check && npm run test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "fuzz": "npm run build && node test/fuzz.mjs --cases 400",
    "bench": "npm run build && node benchmarks/package-bench.mjs",
    "pack:dry": "npm run readme:packages:check && npm pack --dry-run"
  },
  "keywords": [
    "frontier",
    "json",
    "mutation",
    "selector",
    "patch",
    "crdt"
  ],
  "peerDependencies": {
    "@shapeshift-labs/frontier": "0.1.8",
    "@shapeshift-labs/frontier-query": "0.1.2"
  },
  "devDependencies": {
    "@shapeshift-labs/frontier": "0.1.8",
    "@shapeshift-labs/frontier-query": "0.1.2",
    "typescript": "^6.0.3"
  },
  "author": "james addison"
}
